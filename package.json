{
  "name": "wenyanwen",
  "version": "0.1.2",
  "description": "文言文标记语言编译器 - 将 .wyw 文件编译为排版精美的 HTML 页面",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "wenyanwen": "./bin/wyw.js",
    "wyw": "./bin/wyw.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/assets dist/assets && cp src/templates/*.hbs dist/templates/",
    "build:examples": "npm run build && node bin/wyw.js build examples/*.wyw -o examples/dist",
    "build:site": "node web/build.js",
    "dev": "tsc --watch",
    "test": "node --import tsx/esm --test test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md"
  ],
  "keywords": [
    "文言文",
    "classical-chinese",
    "markup",
    "typography"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "handlebars": "^4.7.9"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
